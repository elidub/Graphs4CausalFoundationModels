universe   = vanilla
executable = /bin/bash
arguments  = run_dofm_cluster.sh

output     = logs/dofm_all_$(exp_label).$(ClusterId).$(ProcId).out
error      = logs/dofm_all_$(exp_label).$(ClusterId).$(ProcId).err
log        = logs/dofm_all_$(exp_label).$(ClusterId).$(ProcId).log

# Transfer all necessary files (transfer entire plant_data directory to preserve structure)
transfer_input_files = /fast/arikreuter/DoPFN_v2/CausalPriorFitting/src, /fast/arikreuter/DoPFN_v2/venv.zip, run_dofm_cluster.sh, run_dofm.py, eval.py, /fast/arikreuter/DoPFN_v2/CausalPriorFitting/PlantEval3/PlantsEval/plant_data, /fast/arikreuter/DoPFN_v2/CausalPriorFitting/experiments/FirstTests/checkpoints/final_earlytest_full_conditioning_16773252.0/final_model_with_bardist.pt, /fast/arikreuter/DoPFN_v2/CausalPriorFitting/experiments/FirstTests/checkpoints/final_earlytest_full_conditioning_16773252.0/final_model_with_bardist_config.yaml
should_transfer_files = Yes
when_to_transfer_output = ON_EXIT

# Pass parameters via environment variables
environment = "DATASET=$(dataset) GRAPH_MODE=$(graph_mode) USE_TARGET_ENCODING=$(use_target_encoding) HIDE_BY_CORRELATION=$(hide_by_correlation) TOP_K_EDGES=$(top_k_edges) EXP_NAME=$(exp_name)"

# Resource requests
request_gpus   = 1
request_memory = 32GB
request_cpus   = 4
request_disk   = 16GB

# Job priority bid
JobBatchName = "dofm_planteval3_all"
+MaxRunningPrice = 10000
+RunningPriceExceededAction = "kill"

# Working directory
initialdir = /fast/arikreuter/DoPFN_v2/CausalPriorFitting/PlantEval3/PlantsEval/run_plants

# All configurations tested
# Format: dataset, graph_mode, use_target_encoding, hide_by_correlation, top_k_edges, exp_name, exp_label
queue dataset,graph_mode,use_target_encoding,hide_by_correlation,top_k_edges,exp_name,exp_label from (
    CID_10_ints_10_reals_normal_noise_constant_std.pkl, all_unknown, false, false, 0, planteval3_all_unknown, all_unknown
    CID_10_ints_10_reals_normal_noise_constant_std.pkl, all_unknown, true, false, 0, planteval3_all_unknown_target_enc, all_unknown_te
    CID_10_ints_10_reals_normal_noise_constant_std.pkl, full_graph, false, false, 0, planteval3_full_graph, full_graph
    CID_10_ints_10_reals_normal_noise_constant_std.pkl, full_graph, true, false, 0, planteval3_full_graph_target_enc, full_graph_te
    CID_10_ints_10_reals_normal_noise_constant_std.pkl, full_graph, false, true, 3, planteval3_top3_corr, top3
    CID_10_ints_10_reals_normal_noise_constant_std.pkl, full_graph, true, true, 3, planteval3_top3_target_enc, top3_te
    CID_10_ints_10_reals_normal_noise_constant_std.pkl, full_graph, false, true, 5, planteval3_top5_corr, top5
    CID_10_ints_10_reals_normal_noise_constant_std.pkl, full_graph, true, true, 5, planteval3_top5_target_enc, top5_te
    CID_10_ints_10_reals_normal_noise_constant_std.pkl, full_graph, false, true, 10, planteval3_top10_corr, top10
)
