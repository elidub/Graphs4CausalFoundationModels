universe   = vanilla
executable = /bin/bash
arguments  = run_dofm_no_cond_cluster.sh

output     = logs/dofm_no_cond_$(dataset).$(ClusterId).$(ProcId).out
error      = logs/dofm_no_cond_$(dataset).$(ClusterId).$(ProcId).err
log        = logs/dofm_no_cond_$(dataset).$(ClusterId).$(ProcId).log

# Transfer all necessary files (using non-conditioned checkpoint)
transfer_input_files = /fast/arikreuter/DoPFN_v2/CausalPriorFitting/src, /fast/arikreuter/DoPFN_v2/venv.zip, run_dofm_no_cond_cluster.sh, run_dofm_no_cond.py, eval.py, /fast/arikreuter/DoPFN_v2/CausalPriorFitting/PlantEval/PlantsEval/plant_data, /fast/arikreuter/DoPFN_v2/CausalPriorFitting/experiments/FirstTests/checkpoints/final_earlytest_16773250.0/final_model_with_bardist.pt, /fast/arikreuter/DoPFN_v2/CausalPriorFitting/experiments/FirstTests/checkpoints/final_earlytest_16773250.0/final_model_with_bardist_config.yaml
should_transfer_files = Yes
when_to_transfer_output = ON_EXIT

# Pass parameters via environment variables
environment = "DATASET=$(dataset)"

# Resource requests
request_gpus   = 1
request_memory = 32GB
request_cpus   = 4
request_disk   = 16GB

# Job priority bid
JobBatchName = "dofm_plant_no_cond"
+MaxRunningPrice = 100000
+RunningPriceExceededAction = "kill"

# Working directory
initialdir = /fast/arikreuter/DoPFN_v2/CausalPriorFitting/PlantEval/PlantsEval/run_plants

queue dataset from (
    CID_10_ints_10_reals_normal
)
